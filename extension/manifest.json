{
  "manifest_version": 3,
  "name": "TickTick Extension",
  "version": "1.0",
  "description": "Save articles and generate AI summaries",

  "permissions": [
    "activeTab",
    "storage"
  ],

  "host_permissions": [
    "http://localhost:3000/*",
    "https://ticktickextension-production.up.railway.app/*",
    "https://ticktick.com/*",
    "https://api.ticktick.com/*",
    "https://t.me/*",
    "https://telegram.me/*",
    "<all_urls>"
  ],

  "action": {
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],

  
  "permissions": [
  "identity",
  "storage",
  "activeTab"
]
}
