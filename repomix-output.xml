/**
 * @fileoverview OpenAPI docs for /api/v1/ticktick
 *
 * Routes covered:
 *   GET /api/v1/ticktick/auth     → start OAuth2 flow
 *   GET /api/v1/ticktick/callback → handle TickTick OAuth callback
 *
 * These routes are called by the Chrome extension identity API,
 * not directly by the user. They implement the Authorization Code flow.
 *
 * Rate limited: 5 requests / 15 min per IP (auth limiter)
 */

export const ticktickDocs = {

    '/api/v1/ticktick/auth': {

        get: {
            tags: ['TickTick OAuth'],
            summary: 'Start TickTick OAuth2 authorization',
            description: `
Initiates the TickTick OAuth2 Authorization Code flow.

**How it works:**
1. The Chrome extension calls this endpoint with its own \`redirect_uri\` (a \`chrome.identity\` URL).
2. The server encodes both the extension URI and a nonce into a base64 \`state\` param.
3. The server redirects the browser to TickTick's authorization page.
4. After the user approves, TickTick redirects to \`/api/v1/ticktick/callback\`.

**This endpoint is called by the Chrome extension, not by end users directly.**

**Rate limited:** 5 requests / 15 min per IP
            `.trim(),
            parameters: [
                {
                    name: 'redirect_uri',
                    in: 'query',
                    required: true,
                    description: "The Chrome extension's identity redirect URI. Obtained via `chrome.identity.getRedirectURL('ticktick')`.",
                    schema: {
                        type: 'string',
                        example: 'https://<extension-id>.chromiumapp.org/ticktick'
                    }
                }
            ],
            responses: {
                302: {
                    description: 'Redirects browser to TickTick OAuth authorization page.',
                    headers: {
                        Location: {
                            description: "TickTick's authorization URL with client_id, scope, redirect_uri, and encoded state.",
                            schema: {
                                type: 'string',
                                example: 'https://ticktick.com/oauth/authorize?client_id=...&response_type=code&state=...'
                            }
                        }
                    }
                },
                400: {
                    description: 'Missing redirect_uri query parameter.',
                    content: {
                        'application/json': {
                            schema: { $ref: '#/components/schemas/ErrorResponse' },
                            example: {
                                status: 'error',
                                message: 'Missing extension redirect_uri'
                            }
                        }
                    }
                },
                429: {
                    description: 'Auth rate limit exceeded (5 requests / 15 min).',
                    content: {
                        'application/json': {
                            schema: { $ref: '#/components/schemas/ErrorResponse' },
                            example: {
                                status: 'error',
                                message: 'Too many authentication attempts, please try again later.',
                                retryAfter: '15 minutes'
                            }
                        }
                    }
                }
            }
        }
    },

    '/api/v1/ticktick/callback': {

        get: {
            tags: ['TickTick OAuth'],
            summary: 'Handle TickTick OAuth2 callback',
            description: `
Receives the authorization code from TickTick after the user approves access.

**What happens here:**
1. Validates \`code\` and \`state\` query params.
2. Decodes \`state\` to recover the extension's original \`redirect_uri\`.
3. Exchanges the \`code\` for an \`access_token\` + \`refresh_token\` via TickTick API.
4. Hashes the access token to use as a stable user fingerprint.
5. Upserts the user in MongoDB:
   - **New user** → creates document with a deterministic \`userId\` (format: \`USER_<16 hex chars>\`).
   - **Returning user** → updates tokens only.
6. Redirects the browser back to the extension URI with \`?userId=<userId>\`.

**This endpoint is called by TickTick's servers as a redirect, not directly by you.**

**Rate limited:** 5 requests / 15 min per IP
            `.trim(),
            parameters: [
                {
                    name: 'code',
                    in: 'query',
                    required: true,
                    description: 'Authorization code issued by TickTick.',
                    schema: { type: 'string', example: 'abc123authcode' }
                },
                {
                    name: 'state',
                    in: 'query',
                    required: true,
                    description: 'Base64-encoded JSON containing `extensionRedirectUri` and `nonce`. Set by `/auth`.',
                    schema: { type: 'string', example: 'eyJleHRlbnNpb25SZWRpcmVjdFVyaSI6Imh0dHBzOi8v...' }
                }
            ],
            responses: {
                302: {
                    description: "Redirects to the Chrome extension's redirect URI with the resolved userId.",
                    headers: {
                        Location: {
                            description: 'Extension redirect URI with userId appended as a query param.',
                            schema: {
                                type: 'string',
                                example: 'https://<extension-id>.chromiumapp.org/ticktick?userId=USER_4a9f2c1b3e7d8a0f'
                            }
                        }
                    }
                },
                400: {
                    description: 'Missing code or state parameter.',
                    content: {
                        'application/json': {
                            schema: { $ref: '#/components/schemas/ErrorResponse' },
                            example: {
                                status: 'error',
                                message: 'Missing code or state'
                            }
                        }
                    }
                },
                429: {
                    description: 'Auth rate limit exceeded.',
                    content: {
                        'application/json': {
                            schema: { $ref: '#/components/schemas/ErrorResponse' }
                        }
                    }
                },
                500: {
                    description: 'Token exchange failed, or DB upsert error.',
                    content: {
                        'application/json': {
                            schema: { $ref: '#/components/schemas/ErrorResponse' },
                            example: {
                                status: 'error',
                                message: 'Token exchange failed: invalid_grant'
                            }
                        }
                    }
                }
            }
        }
    }
};
</file>

