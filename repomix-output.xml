/**
 * @fileoverview OpenAPI docs for /api/v1/telegram
 *
 * Routes covered:
 *   POST /api/v1/telegram/webhook → receive Telegram bot updates
 *
 * This endpoint is registered as a webhook with Telegram.
 * Telegram servers call it for every user message/poll answer.
 */

export const telegramDocs = {

    '/api/v1/telegram/webhook': {

        post: {
            tags: ['Telegram Bot'],
            summary: 'Receive Telegram bot updates (webhook)',
            description: `
This endpoint is **registered with Telegram** as the webhook URL. Telegram calls it automatically whenever:
- A user sends a message to your bot (e.g. \`/start USER_<id>\`)
- A user answers a quiz poll

**You don't call this endpoint directly.** It is only hit by Telegram's servers.

**How it connects to your system:**

| Telegram event | What happens |
|---|---|
| \`/start <userId>\` | Links the user's \`telegramChatId\` to their MongoDB document. Enables quiz delivery. |
| Poll answer received | Updates \`QuizPoll.isAnswered = true\` and \`Content.quiz.isSolved = true\`. |

**Bot flow:**
\`\`\`
User sends /start USER_xxx
  → bot registers telegramChatId for that userId
  → confirms connection with a welcome message

Weekly cron fires
  → finds users with telegramChatId + pending quiz content
  → sends Telegram quiz polls
  → stores poll ID in QuizPoll collection

User answers poll
  → Telegram sends poll_answer update to this webhook
  → marks quiz as solved in both QuizPoll and Content
\`\`\`

**Rate limited:** 100 requests / 15 min per IP (general limiter). In practice Telegram won't hit this limit.
            `.trim(),
            requestBody: {
                required: true,
                description: 'Telegram Update object. Shape depends on event type.',
                content: {
                    'application/json': {
                        schema: { $ref: '#/components/schemas/TelegramWebhookRequest' },
                        examples: {
                            startCommand: {
                                summary: '/start command with userId',
                                value: {
                                    update_id: 123456789,
                                    message: {
                                        message_id: 1,
                                        from: { id: 987654321, first_name: 'Ahmed' },
                                        chat: { id: 987654321 },
                                        text: '/start USER_4a9f2c1b3e7d8a0f'
                                    }
                                }
                            },
                            pollAnswer: {
                                summary: 'User answers a quiz poll',
                                value: {
                                    update_id: 123456790,
                                    poll_answer: {
                                        poll_id: 'poll_abc123',
                                        user: { id: 987654321, first_name: 'Ahmed' },
                                        option_ids: [0]
                                    }
                                }
                            }
                        }
                    }
                }
            },
            responses: {
                200: {
                    description: 'Update processed. Telegram requires a 200 response to confirm delivery.',
                    content: {
                        'text/plain': {
                            schema: { type: 'string', example: 'OK' }
                        }
                    }
                },
                500: {
                    description: 'Webhook processing error. Telegram will retry the update.',
                    content: {
                        'text/plain': {
                            schema: { type: 'string', example: 'Internal Server Error' }
                        }
                    }
                }
            }
        }
    }
};
