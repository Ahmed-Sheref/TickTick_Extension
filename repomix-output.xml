  padding: 12px 16px;
  background: var(--surface);
  border-bottom: 1px solid var(--ink-100);
  flex-shrink: 0;
}

.app-header-left {
  display: flex;
  align-items: center;
  gap: var(--space-2);
}

.app-header-name {
  font-size: 13.5px;
  font-weight: 600;
  color: var(--ink-800);
  letter-spacing: -0.01em;
}

/* ═══════════════════════════════════════════════════
   STATUS PILLS
═══════════════════════════════════════════════════ */
.status-pill {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 4px 10px;
  border-radius: var(--r-full);
  font-size: 11.5px;
  font-weight: 600;
  letter-spacing: 0.01em;
}

.status-pill--success {
  background: var(--green-light);
  color: var(--green);
  border: 1px solid var(--green-pill);
}

.status-pill--warning {
  background: var(--amber-light);
  color: var(--amber);
  border: 1px solid #fcd34d;
}

.pill-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: currentColor;
  opacity: 0.7;
}

/* ═══════════════════════════════════════════════════
   TABS
═══════════════════════════════════════════════════ */
.tabs {
  display: flex;
  background: var(--surface);
  border-bottom: 1px solid var(--ink-100);
  padding: 0 16px;
  gap: 0;
  flex-shrink: 0;
}

.tab {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 10px 14px;
  border: none;
  background: transparent;
  font-family: var(--font-body);
  font-size: 13px;
  font-weight: 500;
  color: var(--ink-400);
  cursor: pointer;
  border-bottom: 2px solid transparent;
  margin-bottom: -1px;
  transition: color 0.15s, border-color 0.15s;
  white-space: nowrap;
}

.tab:hover {
  color: var(--ink-700);
}

.tab.active {
  color: var(--accent);
  border-bottom-color: var(--accent);
  font-weight: 600;
}

.tab svg {
  opacity: 0.7;
  transition: opacity 0.15s;
}

.tab.active svg,
.tab:hover svg {
  opacity: 1;
}

/* ═══════════════════════════════════════════════════
   MAIN / PANELS
═══════════════════════════════════════════════════ */
main {
  flex: 1;
  overflow-y: auto;
  padding: 16px 16px 0;
}

.panel {
  display: none;
}

.panel.active {
  display: block;
}

.panel-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--space-3);
  margin-bottom: 14px;
}

.panel-header-text h2 {
  font-size: 16px;
  font-weight: 700;
  color: var(--ink-900);
  letter-spacing: -0.02em;
}

.panel-header-text p {
  font-size: 12.5px;
  color: var(--ink-400);
  margin-top: 2px;
}

/* ═══════════════════════════════════════════════════
   CARDS
═══════════════════════════════════════════════════ */
.card {
  background: var(--surface);
  border-radius: var(--r-lg);
  border: 1px solid var(--ink-100);
  box-shadow: var(--shadow-sm);
  padding: var(--space-5);
  margin-bottom: 12px;
}

.settings-card {
  padding: 16px;
}

.settings-stack {
  display: flex;
  flex-direction: column;
  gap: 0;
  padding-bottom: 16px;
}

.card-label {
  display: flex;
  align-items: center;
  gap: 7px;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.07em;
  text-transform: uppercase;
  color: var(--ink-500);
  margin-bottom: 14px;
}

.card-label-icon {
  font-size: 13px;
  color: var(--ink-400);
}

.card-label-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14px;
}

.card-label-row .card-label {
  margin-bottom: 0;
}

/* ═══════════════════════════════════════════════════
   FORM FIELDS
═══════════════════════════════════════════════════ */
.field {
  display: flex;
  flex-direction: column;
  gap: 5px;
  margin-bottom: 14px;
}

.field:last-of-type {
  margin-bottom: 0;
}

.field-label {
  font-size: 12.5px;
  font-weight: 600;
  color: var(--ink-700);
  display: flex;
  align-items: center;
  gap: 7px;
}

.field-badge {
  font-size: 10px;
  font-weight: 600;
  padding: 2px 6px;
  border-radius: var(--r-full);
  background: var(--accent-light);
  color: var(--accent);
  letter-spacing: 0.04em;
  text-transform: uppercase;
}

.input {
  width: 100%;
  height: 36px;
  padding: 0 12px;
  border: 1.5px solid var(--ink-200);
  border-radius: var(--r-sm);
  background: var(--surface);
  font-family: var(--font-body);
  font-size: 13.5px;
  color: var(--ink-800);
  transition: border-color 0.15s, box-shadow 0.15s;
  outline: none;
}

.input::placeholder {
  color: var(--ink-300);
}

.input:hover {
  border-color: var(--ink-300);
}

.input:focus {
  border-color: var(--accent);
  box-shadow: 0 0 0 3px var(--accent-muted);
}

.input--readonly {
  background: var(--surface-2);
  color: var(--ink-500);
  cursor: default;
  font-family: var(--font-mono);
  font-size: 12px;
}

.input--readonly:focus {
  border-color: var(--ink-200);
  box-shadow: none;
}

.textarea {
  width: 100%;
  padding: 10px 12px;
  border: 1.5px solid var(--ink-200);
  border-radius: var(--r-sm);
  background: var(--surface);
  font-family: var(--font-body);
  font-size: 13px;
  color: var(--ink-800);
  resize: vertical;
  min-height: 110px;
  transition: border-color 0.15s, box-shadow 0.15s;
  outline: none;
  line-height: 1.55;
}

.textarea::placeholder {
  color: var(--ink-300);
}

.textarea:hover {
  border-color: var(--ink-300);
}

.textarea:focus {
  border-color: var(--accent);
  box-shadow: 0 0 0 3px var(--accent-muted);
}

.field-hint {
  font-size: 12px;
  color: var(--ink-400);
  line-height: 1.45;
}

kbd {
  font-family: var(--font-mono);
  font-size: 11.5px;
  background: var(--surface-3);
  border: 1px solid var(--ink-200);
  border-radius: 4px;
  padding: 1px 5px;
  color: var(--ink-600);
}

.input-copy-row {
  display: flex;
  gap: 6px;
}

.input-copy-row .input {
  flex: 1;
}

/* ═══════════════════════════════════════════════════
   OPTION TILES
═══════════════════════════════════════════════════ */
.options-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
  border: none;
  padding: 0;
  margin-bottom: 16px;
}

.options-legend {
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.07em;
  text-transform: uppercase;
  color: var(--ink-500);
  margin-bottom: 10px;
  display: block;
  grid-column: 1/-1;
}

.option-tile {
  cursor: pointer;
  display: block;
}

.option-tile input {
  position: absolute;
  opacity: 0;
  pointer-events: none;
  width: 0;
  height: 0;
}

.option-tile-inner {
  display: flex;
  align-items: flex-start;
  gap: 9px;
  padding: 11px 12px;
  border-radius: var(--r-sm);
  border: 1.5px solid var(--ink-100);
  background: var(--surface-2);
  transition: border-color 0.15s, background 0.15s, box-shadow 0.15s;
}

.option-tile:hover .option-tile-inner {
  border-color: var(--ink-200);
  background: var(--surface);
}

.option-tile input:checked ~ .option-tile-inner {
  border-color: var(--accent);
  background: var(--accent-light);
  box-shadow: 0 0 0 2px var(--accent-muted);
}

.option-icon {
  font-size: 14px;
  line-height: 1;
  color: var(--ink-400);
  margin-top: 1px;
  flex-shrink: 0;
  font-style: normal;
}

.option-tile input:checked ~ .option-tile-inner .option-icon {
  color: var(--accent);
}

.option-text {
  display: flex;
  flex-direction: column;
  gap: 1px;
}

.option-text strong {
  font-size: 12.5px;
  font-weight: 600;
  color: var(--ink-800);
  line-height: 1.2;
}

.option-text small {
  font-size: 11px;
  color: var(--ink-400);
  line-height: 1.3;
}

.option-tile input:checked ~ .option-tile-inner .option-text strong {
  color: var(--accent);
}

/* Focus visible for accessibility */
.option-tile input:focus-visible ~ .option-tile-inner {
  outline: 2px solid var(--accent);
  outline-offset: 2px;
}

/* ═══════════════════════════════════════════════════
   BUTTONS
═══════════════════════════════════════════════════ */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 7px;
  border: none;
  border-radius: var(--r-sm);
  font-family: var(--font-body);
  font-size: 13.5px;
  font-weight: 600;
  cursor: pointer;
  transition: background 0.15s, color 0.15s, box-shadow 0.15s, opacity 0.15s, transform 0.1s;
  white-space: nowrap;
  outline: none;
  padding: 0 14px;
  height: 36px;
}

.btn:focus-visible {
  outline: 2px solid var(--accent);
  outline-offset: 2px;
}

.btn:active:not(:disabled) {
  transform: scale(0.98);
}

.btn:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

/* Primary */
.btn-primary {
  background: var(--ink-900);
  color: #ffffff;
  box-shadow: var(--shadow-xs);
}

.btn-primary:hover:not(:disabled) {
  background: var(--ink-800);
  box-shadow: var(--shadow-sm);
}

/* Secondary */
.btn-secondary {
  background: var(--surface);
  color: var(--ink-700);
  border: 1.5px solid var(--ink-200);
}

.btn-secondary:hover:not(:disabled) {
  background: var(--surface-2);
  border-color: var(--ink-300);
}

/* Ghost */
.btn-ghost {
  background: transparent;
  color: var(--ink-500);
  border: 1.5px solid transparent;
}

.btn-ghost:hover:not(:disabled) {
  background: var(--surface-3);
  color: var(--ink-700);
}

/* Sizes */
.btn-xl {
  height: 44px;
  font-size: 14.5px;
  padding: 0 20px;
  border-radius: var(--r-md);
}

.btn-sm {
  height: 31px;
  font-size: 12.5px;
  padding: 0 11px;
  border-radius: var(--r-xs);
}

.btn-icon {
  width: 36px;
  height: 36px;
  padding: 0;
  flex-shrink: 0;
}

.btn-icon.btn-sm {
  width: 31px;
  height: 31px;
}

.btn-full {
  width: 100%;
  margin-top: 14px;
}

/* ═══════════════════════════════════════════════════
   TOGGLE SWITCH
═══════════════════════════════════════════════════ */
.toggle-switch {
  position: relative;
  display: inline-block;
  cursor: pointer;
  flex-shrink: 0;
}

.toggle-switch input {
  position: absolute;
  opacity: 0;
  width: 0;
  height: 0;
}

.toggle-track {
  display: block;
  width: 42px;
  height: 24px;
  background: var(--ink-200);
  border-radius: var(--r-full);
  transition: background 0.2s;
  position: relative;
}

.toggle-thumb {
  position: absolute;
  top: 3px;
  left: 3px;
  width: 18px;
  height: 18px;
  background: #fff;
  border-radius: 50%;
  box-shadow: var(--shadow-xs);
  transition: transform 0.2s cubic-bezier(.4,0,.2,1);
}

.toggle-switch input:checked + .toggle-track {
  background: var(--accent);
}

.toggle-switch input:checked + .toggle-track .toggle-thumb {
  transform: translateX(18px);
}

.toggle-switch:focus-within .toggle-track {
  outline: 2px solid var(--accent);
  outline-offset: 2px;
}

/* ═══════════════════════════════════════════════════
   TELEGRAM SECTION
═══════════════════════════════════════════════════ */
.telegram-options {
  /* shown by default, hidden via JS */
}

.telegram-options.hidden {
  display: none;
}

.command-block {
  background: var(--surface-2);
  border: 1.5px solid var(--ink-100);
  border-radius: var(--r-sm);
  padding: 10px 13px;
  margin-bottom: 10px;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.command-block-label {
  font-size: 10.5px;
  font-weight: 700;
  letter-spacing: 0.07em;
  text-transform: uppercase;
  color: var(--ink-400);
}

code, .command-block code {
  font-family: var(--font-mono);
  font-size: 12.5px;
  color: var(--ink-700);
  word-break: break-all;
}

.btn-row {
  display: flex;
  gap: 7px;
}

.btn-row .btn {
  flex: 1;
}

/* ═══════════════════════════════════════════════════
   CONNECTION STATUS ROW
═══════════════════════════════════════════════════ */
.connection-status-row {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  margin-bottom: 12px;
}

/* ═══════════════════════════════════════════════════
   STATUS BAR
═══════════════════════════════════════════════════ */
.status-bar {
  flex-shrink: 0;
  padding: 9px 16px;
  font-size: 12.5px;
  font-weight: 500;
  border-top: 1px solid var(--ink-100);
  transition: background 0.2s, color 0.2s;
  min-height: 36px;
  display: flex;
  align-items: center;
}

.status-bar--info {
  background: var(--surface);
  color: var(--ink-400);
}

.status-bar--success {
  background: #f0fdf4;
  color: var(--green);
  border-top-color: #bbf7d0;
}

.status-bar--error {
  background: #fef2f2;
  color: var(--red);
  border-top-color: #fecaca;
}

.status-bar--warning {
  background: var(--amber-light);
  color: var(--amber);
  border-top-color: #fcd34d;
}
</file>

