<file path="extension/popup.css">
/* ═══════════════════════════════════════════════════
   DESIGN TOKENS
═══════════════════════════════════════════════════ */
:root {
  /* Colors */
  --ink-900: #1a1a22;
  --ink-800: #2c2c38;
  --ink-700: #3e3e50;
  --ink-500: #6b6b84;
  --ink-400: #8e8ea8;
  --ink-300: #b5b5cc;
  --ink-200: #dcdce8;
  --ink-100: #f0f0f6;
  --ink-50:  #f7f7fb;

  --surface:   #ffffff;
  --surface-2: #f7f7fb;
  --surface-3: #f0f0f6;

  --accent:        #4f62e8;
  --accent-hover:  #3d4fd6;
  --accent-light:  #eceffe;
  --accent-muted:  rgba(79, 98, 232, 0.12);

  --green:       #16a34a;
  --green-light: #dcfce7;
  --green-pill:  #bbf7d0;

  --amber:       #d97706;
  --amber-light: #fef3c7;

  --red:         #dc2626;
  --red-light:   #fee2e2;

  /* Shadows */
  --shadow-xs: 0 1px 2px rgba(26, 26, 34, 0.06);
  --shadow-sm: 0 2px 8px rgba(26, 26, 34, 0.08), 0 1px 2px rgba(26, 26, 34, 0.04);
  --shadow-md: 0 4px 16px rgba(26, 26, 34, 0.10), 0 1px 4px rgba(26, 26, 34, 0.06);

  /* Radii */
  --r-xs: 6px;
  --r-sm: 10px;
  --r-md: 14px;
  --r-lg: 18px;
  --r-xl: 22px;
  --r-full: 999px;

  /* Spacing */
  --space-1: 4px;
  --space-2: 8px;
  --space-3: 12px;
  --space-4: 16px;
  --space-5: 20px;
  --space-6: 24px;

  /* Typography */
  --font-body: 'DM Sans', ui-sans-serif, system-ui, -apple-system, sans-serif;
  --font-mono: 'JetBrains Mono', ui-monospace, 'Fira Code', monospace;
}

/* ═══════════════════════════════════════════════════
   RESET & BASE
═══════════════════════════════════════════════════ */
*, *::before, *::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

html, body {
  margin: 0;
  padding: 0;
}

body {
  width: 400px;
  min-height: 580px;
  font-family: var(--font-body);
  font-size: 14px;
  line-height: 1.5;
  color: var(--ink-800);
  background: var(--surface-2);
  -webkit-font-smoothing: antialiased;
}

h1, h2, h3, h4, h5, h6 { line-height: 1.25; }
p { line-height: 1.55; }

/* ═══════════════════════════════════════════════════
   LAYOUT SHELL
═══════════════════════════════════════════════════ */
.shell {
  display: flex;
  flex-direction: column;
  min-height: 580px;
}

.view {
  display: none;
  flex-direction: column;
  min-height: 580px;
  flex: 1;
}

.view.active {
  display: flex;
}

/* ═══════════════════════════════════════════════════
   ONBOARDING VIEW
═══════════════════════════════════════════════════ */
.onboard-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 28px 24px 32px;
  gap: var(--space-5);
  background: var(--surface);
}

.onboard-brand {
  display: flex;
  align-items: center;
  gap: var(--space-3);
}

.brand-icon {
  width: 44px;
  height: 44px;
  border-radius: var(--r-md);
  background: var(--ink-900);
  color: #fff;
  display: grid;
  place-items: center;
  flex-shrink: 0;
}

.brand-icon--sm {
  width: 30px;
  height: 30px;
  border-radius: var(--r-xs);
}

.brand-label {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--ink-400);
  margin-bottom: 2px;
}

.brand-title {
  font-size: 20px;
  font-weight: 700;
  color: var(--ink-900);
  letter-spacing: -0.02em;
}

.onboard-hero {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}

.onboard-headline {
  font-size: 22px;
  font-weight: 700;
  color: var(--ink-900);
  letter-spacing: -0.025em;
  line-height: 1.3;
}

.onboard-sub {
  font-size: 14px;
  color: var(--ink-500);
  line-height: 1.6;
}

.onboard-features {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}

.feature-item {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  font-size: 13.5px;
  color: var(--ink-700);
}

.feature-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--accent);
  flex-shrink: 0;
}

.onboard-note {
  font-size: 12px;
  color: var(--ink-400);
  text-align: center;
}

/* ═══════════════════════════════════════════════════
   APP HEADER
═══════════════════════════════════════════════════ */
.app-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 16px;
  background: var(--surface);
  border-bottom: 1px solid var(--ink-100);
  flex-shrink: 0;
}

.app-header-left {
  display: flex;
  align-items: center;
  gap: var(--space-2);
}

.app-header-name {
  font-size: 13.5px;
  font-weight: 600;
  color: var(--ink-800);
  letter-spacing: -0.01em;
}

/* ═══════════════════════════════════════════════════
   STATUS PILLS
═══════════════════════════════════════════════════ */
.status-pill {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 4px 10px;
  border-radius: var(--r-full);
  font-size: 11.5px;
  font-weight: 600;
  letter-spacing: 0.01em;
}

.status-pill--success {
  background: var(--green-light);
  color: var(--green);
  border: 1px solid var(--green-pill);
}

.status-pill--warning {
  background: var(--amber-light);
  color: var(--amber);
  border: 1px solid #fcd34d;
}

.pill-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: currentColor;
  opacity: 0.7;
}

/* ═══════════════════════════════════════════════════
   TABS
═══════════════════════════════════════════════════ */
.tabs {
  display: flex;
  background: var(--surface);
  border-bottom: 1px solid var(--ink-100);
  padding: 0 16px;
  gap: 0;
  flex-shrink: 0;
}

.tab {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 10px 14px;
  border: none;
  background: transparent;
  font-family: var(--font-body);
  font-size: 13px;
  font-weight: 500;
  color: var(--ink-400);
  cursor: pointer;
  border-bottom: 2px solid transparent;
  margin-bottom: -1px;
  transition: color 0.15s, border-color 0.15s;
  white-space: nowrap;
}

.tab:hover {
  color: var(--ink-700);
}

.tab.active {
  color: var(--accent);
  border-bottom-color: var(--accent);
  font-weight: 600;
}

.tab svg {
  opacity: 0.7;
  transition: opacity 0.15s;
}

.tab.active svg,
.tab:hover svg {
  opacity: 1;
}

/* ═══════════════════════════════════════════════════
   MAIN / PANELS
═══════════════════════════════════════════════════ */
main {
  flex: 1;
  overflow-y: auto;
  padding: 16px 16px 0;
}

.panel {
  display: none;
}

.panel.active {
  display: block;
}

.panel-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--space-3);
  margin-bottom: 14px;
}

.panel-header-text h2 {
  font-size: 16px;
  font-weight: 700;
  color: var(--ink-900);
  letter-spacing: -0.02em;
}

.panel-header-text p {
  font-size: 12.5px;
  color: var(--ink-400);
  margin-top: 2px;
}

/* ═══════════════════════════════════════════════════
   CARDS
═══════════════════════════════════════════════════ */
.card {
  background: var(--surface);
  border-radius: var(--r-lg);
  border: 1px solid var(--ink-100);
  box-shadow: var(--shadow-sm);
  padding: var(--space-5);
  margin-bottom: 12px;
}

.settings-card {
  padding: 16px;
}

.settings-stack {
  display: flex;
  flex-direction: column;
  gap: 0;
  padding-bottom: 16px;
}

.card-label {
  display: flex;
  align-items: center;
  gap: 7px;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.07em;
  text-transform: uppercase;
  color: var(--ink-500);
  margin-bottom: 14px;
}

.card-label-icon {
  font-size: 13px;
  color: var(--ink-400);
}

.card-label-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14px;
}

.card-label-row .card-label {
  margin-bottom: 0;
}

/* ═══════════════════════════════════════════════════
   FORM FIELDS
═══════════════════════════════════════════════════ */
.field {
  display: flex;
  flex-direction: column;
  gap: 5px;
  margin-bottom: 14px;
}

.field:last-of-type {
  margin-bottom: 0;
}

.field-label {
  font-size: 12.5px;
  font-weight: 600;
  color: var(--ink-700);
  display: flex;
  align-items: center;
  gap: 7px;
}

.field-badge {
  font-size: 10px;
  font-weight: 600;
  padding: 2px 6px;
  border-radius: var(--r-full);
  background: var(--accent-light);
  color: var(--accent);
  letter-spacing: 0.04em;
  text-transform: uppercase;
}

.input {
  width: 100%;
  height: 36px;
  padding: 0 12px;
  border: 1.5px solid var(--ink-200);
  border-radius: var(--r-sm);
  background: var(--surface);
  font-family: var(--font-body);
  font-size: 13.5px;
  color: var(--ink-800);
  transition: border-color 0.15s, box-shadow 0.15s;
  outline: none;
}

.input::placeholder {
  color: var(--ink-300);
}

.input:hover {
  border-color: var(--ink-300);
}

.input:focus {
  border-color: var(--accent);
  box-shadow: 0 0 0 3px var(--accent-muted);
}

.input--readonly {
  background: var(--surface-2);
  color: var(--ink-500);
  cursor: default;
  font-family: var(--font-mono);
  font-size: 12px;
}

.input--readonly:focus {
  border-color: var(--ink-200);
  box-shadow: none;
}

.textarea {
  width: 100%;
  padding: 10px 12px;
  border: 1.5px solid var(--ink-200);
  border-radius: var(--r-sm);
  background: var(--surface);
  font-family: var(--font-body);
  font-size: 13px;
  color: var(--ink-800);
  resize: vertical;
  min-height: 110px;
  transition: border-color 0.15s, box-shadow 0.15s;
  outline: none;
  line-height: 1.55;
}

.textarea::placeholder {
  color: var(--ink-300);
}

.textarea:hover {
  border-color: var(--ink-300);
}

.textarea:focus {
  border-color: var(--accent);
  box-shadow: 0 0 0 3px var(--accent-muted);
}

.field-hint {
  font-size: 12px;
  color: var(--ink-400);
  line-height: 1.45;
}

kbd {
  font-family: var(--font-mono);
  font-size: 11.5px;
  background: var(--surface-3);
  border: 1px solid var(--ink-200);
  border-radius: 4px;
  padding: 1px 5px;
  color: var(--ink-600);
}

.input-copy-row {
  display: flex;
  gap: 6px;
}

.input-copy-row .input {
  flex: 1;
}

/* ═══════════════════════════════════════════════════
   OPTION TILES
═══════════════════════════════════════════════════ */
.options-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
  border: none;
  padding: 0;
  margin-bottom: 16px;
}

.options-legend {
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.07em;
  text-transform: uppercase;
  color: var(--ink-500);
  margin-bottom: 10px;
  display: block;
  grid-column: 1/-1;
}

.option-tile {
  cursor: pointer;
  display: block;
}

.option-tile input {
  position: absolute;
  opacity: 0;
  pointer-events: none;
  width: 0;
  height: 0;
}

.option-tile-inner {
  display: flex;
  align-items: flex-start;
  gap: 9px;
  padding: 11px 12px;
  border-radius: var(--r-sm);
  border: 1.5px solid var(--ink-100);
  background: var(--surface-2);
  transition: border-color 0.15s, background 0.15s, box-shadow 0.15s;
}

.option-tile:hover .option-tile-inner {
  border-color: var(--ink-200);
  background: var(--surface);
}

.option-tile input:checked ~ .option-tile-inner {
  border-color: var(--accent);
  background: var(--accent-light);
  box-shadow: 0 0 0 2px var(--accent-muted);
}

.option-icon {
  font-size: 14px;
  line-height: 1;
  color: var(--ink-400);
  margin-top: 1px;
  flex-shrink: 0;
  font-style: normal;
}

.option-tile input:checked ~ .option-tile-inner .option-icon {
  color: var(--accent);
}

.option-text {
  display: flex;
  flex-direction: column;
  gap: 1px;
}

.option-text strong {
  font-size: 12.5px;
  font-weight: 600;
  color: var(--ink-800);
  line-height: 1.2;
}

.option-text small {
  font-size: 11px;
  color: var(--ink-400);
  line-height: 1.3;
}

.option-tile input:checked ~ .option-tile-inner .option-text strong {
  color: var(--accent);
}

/* Focus visible for accessibility */
.option-tile input:focus-visible ~ .option-tile-inner {
  outline: 2px solid var(--accent);
  outline-offset: 2px;
}

/* ═══════════════════════════════════════════════════
   BUTTONS
═══════════════════════════════════════════════════ */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 7px;
  border: none;
  border-radius: var(--r-sm);
  font-family: var(--font-body);
  font-size: 13.5px;
  font-weight: 600;
  cursor: pointer;
  transition: background 0.15s, color 0.15s, box-shadow 0.15s, opacity 0.15s, transform 0.1s;
  white-space: nowrap;
  outline: none;
  padding: 0 14px;
  height: 36px;
}

.btn:focus-visible {
  outline: 2px solid var(--accent);
  outline-offset: 2px;
}

.btn:active:not(:disabled) {
  transform: scale(0.98);
}

.btn:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

/* Primary */
.btn-primary {
  background: var(--ink-900);
  color: #ffffff;
  box-shadow: var(--shadow-xs);
}

.btn-primary:hover:not(:disabled) {
  background: var(--ink-800);
  box-shadow: var(--shadow-sm);
}

/* Secondary */
.btn-secondary {
  background: var(--surface);
  color: var(--ink-700);
  border: 1.5px solid var(--ink-200);
}

.btn-secondary:hover:not(:disabled) {
  background: var(--surface-2);
  border-color: var(--ink-300);
}

/* Ghost */
.btn-ghost {
  background: transparent;
  color: var(--ink-500);
  border: 1.5px solid transparent;
}

.btn-ghost:hover:not(:disabled) {
  background: var(--surface-3);
  color: var(--ink-700);
}

/* Sizes */
.btn-xl {
  height: 44px;
  font-size: 14.5px;
  padding: 0 20px;
  border-radius: var(--r-md);
}

.btn-sm {
  height: 31px;
  font-size: 12.5px;
  padding: 0 11px;
  border-radius: var(--r-xs);
}

.btn-icon {
  width: 36px;
  height: 36px;
  padding: 0;
  flex-shrink: 0;
}

.btn-icon.btn-sm {
  width: 31px;
  height: 31px;
}

.btn-full {
  width: 100%;
  margin-top: 14px;
}

/* ═══════════════════════════════════════════════════
   TOGGLE SWITCH
═══════════════════════════════════════════════════ */
.toggle-switch {
  position: relative;
  display: inline-block;
  cursor: pointer;
  flex-shrink: 0;
}

.toggle-switch input {
  position: absolute;
  opacity: 0;
  width: 0;
  height: 0;
}

.toggle-track {
  display: block;
  width: 42px;
  height: 24px;
  background: var(--ink-200);
  border-radius: var(--r-full);
  transition: background 0.2s;
  position: relative;
}

.toggle-thumb {
  position: absolute;
  top: 3px;
  left: 3px;
  width: 18px;
  height: 18px;
  background: #fff;
  border-radius: 50%;
  box-shadow: var(--shadow-xs);
  transition: transform 0.2s cubic-bezier(.4,0,.2,1);
}

.toggle-switch input:checked + .toggle-track {
  background: var(--accent);
}

.toggle-switch input:checked + .toggle-track .toggle-thumb {
  transform: translateX(18px);
}

.toggle-switch:focus-within .toggle-track {
  outline: 2px solid var(--accent);
  outline-offset: 2px;
}

/* ═══════════════════════════════════════════════════
   TELEGRAM SECTION
═══════════════════════════════════════════════════ */
.telegram-options {
  /* shown by default, hidden via JS */
}

.telegram-options.hidden {
  display: none;
}

.command-block {
  background: var(--surface-2);
  border: 1.5px solid var(--ink-100);
  border-radius: var(--r-sm);
  padding: 10px 13px;
  margin-bottom: 10px;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.command-block-label {
  font-size: 10.5px;
  font-weight: 700;
  letter-spacing: 0.07em;
  text-transform: uppercase;
  color: var(--ink-400);
}

code, .command-block code {
  font-family: var(--font-mono);
  font-size: 12.5px;
  color: var(--ink-700);
  word-break: break-all;
}

.btn-row {
  display: flex;
  gap: 7px;
}

.btn-row .btn {
  flex: 1;
}

/* ═══════════════════════════════════════════════════
   CONNECTION STATUS ROW
═══════════════════════════════════════════════════ */
.connection-status-row {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  margin-bottom: 12px;
}

/* ═══════════════════════════════════════════════════
   STATUS BAR
═══════════════════════════════════════════════════ */
.status-bar {
  flex-shrink: 0;
  padding: 9px 16px;
  font-size: 12.5px;
  font-weight: 500;
  border-top: 1px solid var(--ink-100);
  transition: background 0.2s, color 0.2s;
  min-height: 36px;
  display: flex;
  align-items: center;
}

.status-bar--info {
  background: var(--surface);
  color: var(--ink-400);
}

.status-bar--success {
  background: #f0fdf4;
  color: var(--green);
  border-top-color: #bbf7d0;
}

.status-bar--error {
  background: #fef2f2;
  color: var(--red);
  border-top-color: #fecaca;
}

.status-bar--warning {
  background: var(--amber-light);
  color: var(--amber);
  border-top-color: #fcd34d;
}
</file>

<file path="extension/popup.html">
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>TickTick Extension</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="popup.css" />
</head>
<body>
<div class="shell">

  <!-- ═══════════════════════════════════════
       ONBOARDING VIEW
  ═══════════════════════════════════════ -->
  <div id="onboardingView" class="view active">
    <div class="onboard-wrap">

      <div class="onboard-brand">
        <div class="brand-icon">
          <svg width="22" height="22" viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M4 11L9 16L18 6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div>
          <p class="brand-label">Knowledge Workspace</p>
          <h1 class="brand-title">TickTick Extension</h1>
        </div>
      </div>

      <div class="onboard-hero">
        <h2 class="onboard-headline">Connect your TickTick<br/>account to get started</h2>
        <p class="onboard-sub">Link once, then capture articles, generate AI summaries, and review them with Telegram quizzes — all in one place.</p>
      </div>

      <ul class="onboard-features" role="list">
        <li class="feature-item">
          <span class="feature-dot"></span>
          <span>One identity across browsers</span>
        </li>
        <li class="feature-item">
          <span class="feature-dot"></span>
          <span>Article saving with AI enrichment</span>
        </li>
        <li class="feature-item">
          <span class="feature-dot"></span>
          <span>Weekly email digest + Telegram quizzes</span>
        </li>
      </ul>

      <button id="connectTickTickBtn" class="btn btn-primary btn-xl" type="button">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 1v6M8 1L5 4M8 1l3 3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/><path d="M2 9v4a1 1 0 001 1h10a1 1 0 001-1V9" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
        Connect with TickTick
      </button>

      <p class="onboard-note">After connecting, this popup unlocks automatically.</p>

    </div>
  </div>

  <!-- ═══════════════════════════════════════
       APP VIEW
  ═══════════════════════════════════════ -->
  <div id="appView" class="view">

    <!-- Header -->
    <header class="app-header">
      <div class="app-header-left">
        <div class="brand-icon brand-icon--sm">
          <svg width="14" height="14" viewBox="0 0 22 22" fill="none"><path d="M4 11L9 16L18 6" stroke="currentColor" stroke-width="2.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <span class="app-header-name">TickTick Extension</span>
      </div>
      <div id="ticktickStatusPill" class="status-pill status-pill--success">
        <span class="pill-dot"></span>
        Connected
      </div>
    </header>

    <!-- Tab Navigation -->
    <nav class="tabs" role="tablist" aria-label="Main sections">
      <button id="tabSave" class="tab active" type="button" role="tab" aria-selected="true" aria-controls="panelSave">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M13 2H3a1 1 0 00-1 1v10a1 1 0 001 1h10a1 1 0 001-1V3a1 1 0 00-1-1z" stroke="currentColor" stroke-width="1.6"/><path d="M5 8h6M5 11h4M5 5h2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
        Save Article
      </button>
      <button id="tabSettings" class="tab" type="button" role="tab" aria-selected="false" aria-controls="panelSettings">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="2.5" stroke="currentColor" stroke-width="1.6"/><path d="M8 1v1.5M8 13.5V15M1 8h1.5M13.5 8H15M2.93 2.93l1.06 1.06M12.01 12.01l1.06 1.06M2.93 13.07l1.06-1.06M12.01 3.99l1.06-1.06" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
        Settings
      </button>
    </nav>

    <!-- Main Content -->
    <main>

      <!-- ─── SAVE ARTICLE PANEL ─── -->
      <section id="panelSave" class="panel active" role="tabpanel" aria-labelledby="tabSave">

        <div class="panel-header">
          <div class="panel-header-text">
            <h2>Save Current Article</h2>
            <p>Capture the page and enrich it with smart options before saving.</p>
          </div>
          <button id="refreshPageBtn" class="btn btn-ghost btn-icon" type="button" title="Reload page context" aria-label="Refresh page context">
            <svg width="15" height="15" viewBox="0 0 16 16" fill="none"><path d="M13.5 8A5.5 5.5 0 112.5 5M2.5 2v3h3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
        </div>

        <div class="card">

          <div class="field">
            <label class="field-label" for="title">Title</label>
            <input id="title" class="input" type="text" placeholder="Article title…" autocomplete="off" />
          </div>

          <div class="field">
            <label class="field-label" for="url">URL</label>
            <input id="url" class="input" type="url" placeholder="https://example.com/article" autocomplete="off" />
          </div>

          <div class="field">
            <label class="field-label" for="rawText">
              Article Text
              <span class="field-badge">auto-filled</span>
            </label>
            <textarea id="rawText" class="textarea" rows="7" placeholder="Selected text appears here — or paste manually…"></textarea>
            <p class="field-hint">Selected text is preferred. Falls back to page content if nothing is selected.</p>
          </div>

          <div class="field">
            <label class="field-label" for="userInput">
              List &amp; Tags
            </label>
            <input id="userInput" class="input" type="text" placeholder="~learning #nodejs #backend" autocomplete="off" />
            <p class="field-hint">Use <kbd>~</kbd> for a list and <kbd>#</kbd> for tags.</p>
          </div>

          <fieldset class="options-grid" aria-label="AI enrichment options">
            <legend class="options-legend">Enrichment Options</legend>

            <label class="option-tile">
              <input id="useSummaryAi" type="checkbox" checked />
              <span class="option-tile-inner">
                <span class="option-icon">✦</span>
                <span class="option-text">
                  <strong>AI Summary</strong>
                  <small>Generate a concise summary</small>
                </span>
              </span>
            </label>

            <label class="option-tile">
              <input id="useTagsAi" type="checkbox" checked />
              <span class="option-tile-inner">
                <span class="option-icon">⊞</span>
                <span class="option-text">
                  <strong>AI Tags</strong>
                  <small>Suggest relevant tags</small>
                </span>
              </span>
            </label>

            <label class="option-tile">
              <input id="useQuiz" type="checkbox" checked />
              <span class="option-tile-inner">
                <span class="option-icon">◎</span>
                <span class="option-text">
                  <strong>Quiz</strong>
                  <small>Create one review question</small>
                </span>
              </span>
            </label>

            <label class="option-tile">
              <input id="mergeWithUserText" type="checkbox" />
              <span class="option-tile-inner">
                <span class="option-icon">⊕</span>
                <span class="option-text">
                  <strong>Merge Summary</strong>
                  <small>Append summary to saved text</small>
                </span>
              </span>
            </label>

          </fieldset>

          <button id="saveArticleBtn" class="btn btn-primary btn-full" type="button">
            <svg width="15" height="15" viewBox="0 0 16 16" fill="none"><path d="M13 2H3a1 1 0 00-1 1v10a1 1 0 001 1h10a1 1 0 001-1V3a1 1 0 00-1-1z" stroke="currentColor" stroke-width="1.7"/><path d="M10.5 2v4a.5.5 0 01-.5.5H6a.5.5 0 01-.5-.5V2" stroke="currentColor" stroke-width="1.7"/><path d="M3 10.5h10" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg>
            Save Article
          </button>

        </div>
      </section>

      <!-- ─── SETTINGS PANEL ─── -->
      <section id="panelSettings" class="panel" role="tabpanel" aria-labelledby="tabSettings">

        <div class="panel-header">
          <div class="panel-header-text">
            <h2>Settings</h2>
            <p>Identity, email, Telegram, and TickTick connection.</p>
          </div>
        </div>

        <div class="settings-stack">

          <!-- Identity -->
          <div class="card settings-card">
            <div class="card-label">
              <span class="card-label-icon">⊙</span>
              Identity
            </div>
            <div class="field">
              <label class="field-label" for="userId">Your User ID</label>
              <div class="input-copy-row">
                <input id="userId" class="input input--readonly" type="text" readonly aria-label="Your User ID" />
                <button id="copyUserIdBtn" class="btn btn-ghost btn-icon" type="button" title="Copy User ID" aria-label="Copy User ID">
                  <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><rect x="5" y="5" width="8" height="8" rx="1.5" stroke="currentColor" stroke-width="1.6"/><path d="M3 11V3h8" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </button>
              </div>
              <p class="field-hint">This ID links your extension, email digest, and Telegram bot.</p>
            </div>
          </div>

          <!-- Email Preferences -->
          <div class="card settings-card">
            <div class="card-label-row">
              <div class="card-label">
                <span class="card-label-icon">✉</span>
                Email Digest
              </div>
              <label class="toggle-switch" aria-label="Enable weekly email digest">
                <input type="checkbox" id="weeklyEmailToggle" />
                <span class="toggle-track"><span class="toggle-thumb"></span></span>
              </label>
            </div>
            <div class="field">
              <label class="field-label" for="email">Email Address</label>
              <input id="email" class="input" type="email" placeholder="name@example.com" autocomplete="email" />
            </div>
            <p class="field-hint">Receive a weekly digest of your saved articles when enabled.</p>
            <button id="saveEmailSettingsBtn" class="btn btn-secondary btn-full" type="button">Save Email Settings</button>
          </div>

          <!-- Telegram & Quiz -->
          <div class="card settings-card">
            <div class="card-label-row">
              <div class="card-label">
                <span class="card-label-icon">⟴</span>
                Telegram &amp; Quiz
              </div>
              <label class="toggle-switch" aria-label="Enable Telegram quiz">
                <input type="checkbox" id="telegramQuizToggle" />
                <span class="toggle-track"><span class="toggle-thumb"></span></span>
              </label>
            </div>

            <div class="telegram-options" id="telegramOptions">
              <p class="field-hint" style="margin-bottom: 12px;">Send yourself the command below in Telegram to activate your quiz bot. You'll receive weekly quiz questions from your saved articles.</p>

              <div class="command-block">
                <span class="command-block-label">Start command</span>
                <code id="telegramCommand">/start</code>
              </div>

              <div class="btn-row">
                <button id="copyTelegramCommandBtn" class="btn btn-ghost btn-sm" type="button">
                  <svg width="13" height="13" viewBox="0 0 16 16" fill="none"><rect x="5" y="5" width="8" height="8" rx="1.5" stroke="currentColor" stroke-width="1.6"/><path d="M3 11V3h8" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  Copy Command
                </button>
                <button id="openTelegramBotBtn" class="btn btn-primary btn-sm" type="button">
                  <svg width="13" height="13" viewBox="0 0 16 16" fill="none"><path d="M6 3H3a1 1 0 00-1 1v9a1 1 0 001 1h9a1 1 0 001-1v-3M9 2h5m0 0v5m0-5L7 10" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  Open Telegram Bot
                </button>
              </div>
            </div>

            <button id="saveQuizSettingsBtn" class="btn btn-secondary btn-full" type="button">Save Quiz Preferences</button>
          </div>

          <!-- TickTick Connection -->
          <div class="card settings-card">
            <div class="card-label">
              <span class="card-label-icon">⟳</span>
              TickTick Connection
            </div>
            <div class="connection-status-row">
              <div id="ticktickStatusSecondary" class="status-pill status-pill--success">
                <span class="pill-dot"></span>
                Connected
              </div>
              <p class="field-hint" style="margin:0; flex:1">Your TickTick account is linked to this extension.</p>
            </div>
            <button id="reconnectTickTickBtn" class="btn btn-ghost btn-full" type="button">Reconnect TickTick</button>
          </div>

        </div>
      </section>

    </main>

    <!-- Status Bar -->
    <div id="statusBar" class="status-bar status-bar--info" role="status" aria-live="polite">Ready</div>

  </div><!-- /appView -->

</div><!-- /shell -->
<script src="popup.js"></script>
</body>
</html>
</file>

<file path="extension/popup.js">
const API_BASE = "http://localhost:3000/api/v1";
const TELEGRAM_BOT_USERNAME = "Tick_review_bot"; // ← غير هذا لاسم البوت الحقيقي
const STORAGE_KEYS = {
  userId: "ticktick_userId",
  connected: "ticktick_connected",
  email: "ticktick_email",
  weeklyEmailToggle: "ticktick_weeklyEmailToggle",
  telegramQuizToggle: "ticktick_telegramQuizToggle"
};

const el = {
  onboardingView: document.getElementById("onboardingView"),
  appView: document.getElementById("appView"),
  statusBar: document.getElementById("statusBar"),
  ticktickStatusPill: document.getElementById("ticktickStatusPill"),
  ticktickStatusSecondary: document.getElementById("ticktickStatusSecondary"),
  connectTickTickBtn: document.getElementById("connectTickTickBtn"),
  reconnectTickTickBtn: document.getElementById("reconnectTickTickBtn"),
  tabSave: document.getElementById("tabSave"),
  tabSettings: document.getElementById("tabSettings"),
  panelSave: document.getElementById("panelSave"),
  panelSettings: document.getElementById("panelSettings"),
  title: document.getElementById("title"),
  url: document.getElementById("url"),
  rawText: document.getElementById("rawText"),
  userInput: document.getElementById("userInput"),
  useSummaryAi: document.getElementById("useSummaryAi"),
  useTagsAi: document.getElementById("useTagsAi"),
  useQuiz: document.getElementById("useQuiz"),
  mergeWithUserText: document.getElementById("mergeWithUserText"),
  refreshPageBtn: document.getElementById("refreshPageBtn"),
  saveArticleBtn: document.getElementById("saveArticleBtn"),
  userId: document.getElementById("userId"),
  copyUserIdBtn: document.getElementById("copyUserIdBtn"),
  email: document.getElementById("email"),
  weeklyEmailToggle: document.getElementById("weeklyEmailToggle"),
  saveEmailSettingsBtn: document.getElementById("saveEmailSettingsBtn"),
  telegramQuizToggle: document.getElementById("telegramQuizToggle"),
  telegramCommand: document.getElementById("telegramCommand"),
  copyTelegramCommandBtn: document.getElementById("copyTelegramCommandBtn"),
  openTelegramBotBtn: document.getElementById("openTelegramBotBtn"),
  saveQuizSettingsBtn: document.getElementById("saveQuizSettingsBtn"),
  telegramOptions: document.getElementById("telegramOptions")
};

// ══════════════════════════════════════════
// HELPERS
// ══════════════════════════════════════════

function setStatus(message, type = "info") {
  el.statusBar.textContent = message;
  // Map type names to new BEM class names
  const typeMap = { info: "info", success: "success", error: "error", warning: "warning" };
  const t = typeMap[type] || "info";
  el.statusBar.className = `status-bar status-bar--${t}`;
}

function setButtonLoading(button, loading, loadingText) {
  if (!button) return;
  if (!button.dataset.defaultText) button.dataset.defaultText = button.textContent.trim();
  button.disabled = loading;
  button.textContent = loading ? loadingText : button.dataset.defaultText;
}

function setConnectedState(connected) {
  el.onboardingView.classList.toggle("active", !connected);
  el.appView.classList.toggle("active", connected);

  const pillClass = connected ? "status-pill status-pill--success" : "status-pill status-pill--warning";
  const pillText = connected ? "Connected" : "Not Connected";
  const pillDot = `<span class="pill-dot"></span>`;

  [el.ticktickStatusPill, el.ticktickStatusSecondary].forEach(pill => {
    if (!pill) return;
    pill.className = pillClass;
    pill.innerHTML = `${pillDot} ${pillText}`;
  });
}

function switchTab(name) {
  const saveActive = name === "save";
  el.tabSave.classList.toggle("active", saveActive);
  el.tabSave.setAttribute("aria-selected", String(saveActive));
  el.tabSettings.classList.toggle("active", !saveActive);
  el.tabSettings.setAttribute("aria-selected", String(!saveActive));
  el.panelSave.classList.toggle("active", saveActive);
  el.panelSettings.classList.toggle("active", !saveActive);
  if (saveActive) loadPageContext();
}

function storageGet(keys) {
  return new Promise((resolve) => chrome.storage.local.get(keys, resolve));
}

function storageSet(data) {
  return new Promise((resolve) => chrome.storage.local.set(data, resolve));
}

async function getActiveTab() {
  const tabs = await chrome.tabs.query({ active: true, currentWindow: true });
  return tabs[0];
}

